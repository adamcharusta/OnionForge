{
  "ConnectionStrings": {
    "Database": "Server=localhost,1433;Database={{SolutionName}};User Id=sa;Password={{SaPassword}};TrustServerCertificate=True"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "AllowedHosts": "*"
}
