# Runtime environment of the api container. Development exposes the tool UIs
# (Scalar/OpenAPI, dashboards); switch to Production to test production behavior.
ASPNETCORE_ENVIRONMENT=Development

MSSQL_SA_PASSWORD=Change_this_strong_password1!

# Every service added to docker-compose.yml documents its credentials here
# (see the service snippets in templates/MANIFEST.md), e.g.:
# RABBITMQ_USER=admin
# RABBITMQ_PASSWORD=Change_this_password1!
# REDIS_PASSWORD=Change_this_password1!
